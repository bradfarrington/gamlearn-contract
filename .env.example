# Copy this file to .env.local and fill in real values, then run `vercel dev`.
# .env.local is gitignored — your secrets stay on your machine.

# Resend API key — create at https://resend.com (Settings → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — must be on a domain verified in Resend (e.g. thedigicraft.co.uk).
# For quick testing before your domain is verified, Resend allows: onboarding@resend.dev
FROM_EMAIL=contracts@thedigicraft.co.uk

# Where signed contracts (with the full audit trail) get sent to you
NOTIFY_EMAIL=hello@thedigicraft.co.uk
